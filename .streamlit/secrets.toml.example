# Copy this file to .streamlit/secrets.toml for local development.
# On Streamlit Cloud, add these keys via:
#   App dashboard → Settings → Secrets → paste the key=value pairs.
#
# How to add GITHUB_TOKEN to Streamlit Cloud:
#   1. Go to https://github.com/settings/tokens/new
#   2. Select "Fine-grained token" (or classic token with "repo" scope)
#   3. For fine-grained: set Repository access → Only select repositories
#      → agamaded-sudo/broker-investor-agents-lite
#      → Permissions → Contents: Read and Write
#   4. Generate and copy the token
#   5. In Streamlit Cloud: open your app → ⋮ menu → Settings → Secrets
#   6. Paste exactly:
#        GITHUB_TOKEN = "github_pat_xxxxxxxxxxxx"
#   7. Save — the app restarts automatically

GITHUB_TOKEN = "your_github_token_here"

# Password shown on the login screen. Remove or leave blank to disable auth (local dev).
APP_PASSWORD = "your_password_here"

# Anthropic API key for Arabic translation (optional — UI stays in English if absent).
# On Streamlit Cloud: add this key in App dashboard → Settings → Secrets.
# For local dev: create .env.local (git-ignored) with:
#   ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# NOTE: .env.local must be saved WITHOUT a UTF-8 BOM (use UTF-8 encoding).
ANTHROPIC_API_KEY = "sk-ant-api03-your-key-here"
